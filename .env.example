# ===========================================
# DJEN Monitor - Configuração de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha os valores

# ===========================================
# Banco de Dados
# ===========================================
DATABASE_URL="postgresql://usuario:senha@host:5432/djen_monitor?schema=public"

# ===========================================
# Servidor
# ===========================================
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ===========================================
# Integração Juris Agenda
# ===========================================
JURIS_AGENDA_WEBHOOK_URL="https://juris-agenda.com/api/webhooks/djen"
JURIS_AGENDA_API_KEY="sua-api-key-aqui"

# ===========================================
# Evolution API (WhatsApp) - Mesma do Juris Agenda
# ===========================================
EVOLUTION_API_URL="https://evolution-api.exemplo.com"
EVOLUTION_API_KEY="sua-chave-api-evolution"
EVOLUTION_INSTANCE="juris-agenda"

# ===========================================
# SMTP (E-mail)
# ===========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="DJEN Monitor <noreply@juris-agenda.com>"

# ===========================================
# CNJ Comunica API
# ===========================================
CNJ_COMUNICA_BASE_URL="https://comunicaapi.pje.jus.br"
CNJ_COMUNICA_TIMEOUT=30000

# ===========================================
# Cron Schedules (Padrão - Railway)
# ===========================================
# Busca diária: 7h de seg a sex
CRON_DAILY_SEARCH="0 7 * * 1-5"
# Processador de notificações: a cada 4h
CRON_NOTIFY_PROCESSOR="0 */4 * * *"
# Atualização de feriados: 1º de janeiro
CRON_HOLIDAYS_UPDATE="0 0 1 1 *"
